# Copy to .env.local and fill in. These are also set in the Vercel project
# (Settings → Environment Variables) so the contact form works in production.

# Resend API key — https://resend.com/api-keys (required)
RESEND_API_KEY=

# Where form submissions are delivered (defaults to contact@datacentra.io)
# CONTACT_TO=contact@datacentra.io

# Verified Resend sender. The domain must be verified in Resend.
# For quick testing before verifying datacentra.io, use: onboarding@resend.dev
# CONTACT_FROM=DataCentra Website <noreply@datacentra.io>
